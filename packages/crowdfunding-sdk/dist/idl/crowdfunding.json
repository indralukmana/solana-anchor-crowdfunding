                    },
                    {
                        "name": "creator",
                        "docs": [
                            "The public key of the creator who received the funds."
                        ],
                        "type": "pubkey"
                    },
                    {
                        "name": "amount",
                        "docs": [
                            "The total amount of lamports withdrawn."
                        ],
                        "type": "u64"
                    }
                ]
            }
