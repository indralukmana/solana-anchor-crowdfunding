{
  "name": "solana-anchor-crowdfunding-monorepo",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "anchor:build": "cd apps/crowdfunding-anchor && anchor build",
    "sdk:sync": "pnpm --filter @crowdfunding/sdk sync",
    "sdk:build": "pnpm --filter @crowdfunding/sdk build",
    "program:build": "pnpm anchor:build && pnpm sdk:sync && pnpm sdk:build"
  }
}
